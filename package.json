{
  "name": "church-erp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "bash scripts/check.sh",
    "local:setup": "bash scripts/local-setup.sh",
    "https:setup": "bash scripts/https-setup.sh",
    "phone:network": "bash scripts/windows-phone-network.sh",
    "dev:phone": "bash scripts/dev-phone.sh",
    "test:smoke": "bash scripts/smoke-test.sh",
    "songs:sync-jemaf": "node scripts/sync-jemaf-catalog.mjs",
    "songs:render-seed": "node scripts/sync-jemaf-catalog.mjs render",
    "songs:import-base-chants": "node scripts/import-base-chants.mjs",
    "songs:import-official-pdfs": "node scripts/import-official-pdfs.mjs",
    "songs:import-chordpro-catalog": "node scripts/import-chordpro-catalog.mjs",
    "songs:import-musicxml-catalog": "node scripts/import-musicxml-catalog.mjs",
    "songs:delete-collection": "node scripts/delete-song-collection.mjs",
    "songs:clear-base-chants": "node scripts/clear-base-chants.mjs",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset && node scripts/import-base-chants.mjs --all --include-official --target local",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "jspdf": "^4.2.1",
    "next": "16.2.9",
    "opensheetmusicdisplay": "^2.0.0",
    "pdfjs-dist": "^6.0.227",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "supabase": "^2.106.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
