# Local Supabase PostgreSQL connection used by server-side application code.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15432/postgres

# Local Supabase Storage API used only by server-side route handlers.
SUPABASE_URL=http://127.0.0.1:15431
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-secret-key-from-pnpm-db-status

# Temporary MVP login. Every authenticated user is treated as an administrator.
CHURCHERP_LOGIN_PASSWORD=louange
AUTH_SESSION_SECRET=replace-with-random-local-secret
